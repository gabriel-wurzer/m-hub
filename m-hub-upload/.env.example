PORT=3300
# Internal SeaweedFS filer (docker DNS). On-finish PUTs the assembled file here.
SEAWEED_FILER_INTERNAL_URL=http://seaweed-filer:8888
# m-hub JWT secret (HS256). Empty = DEV, auth disabled. Set in prod.
JWT_SECRET=
# Where tus keeps in-progress uploads (mount a volume in prod).
UPLOAD_DIR=/data/tus
# Max upload size in bytes (default 5 GB).
MAX_BYTES=5368709120
